<idea-plugin require-restart="true">
    <id>dev.ckob.lazygit</id>
    <name>Lazygit</name>
    <vendor url="https://ckob.dev">ckob</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>
    <depends optional="true" config-file="lazygit-ideavim.xml">IdeaVIM</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.ckob.lazygit.LazygitEditorProvider"/>
        <applicationService serviceImplementation="dev.ckob.lazygit.LazygitSettingsState"/>
        <applicationConfigurable parentId="tools" instance="dev.ckob.lazygit.LazygitSettingsConfigurable" id="dev.ckob.lazygit.LazygitSettingsConfigurable" displayName="Lazygit"/>
    </extensions>

    <actions>
        <action id="Lazygit.Toggle" class="dev.ckob.lazygit.LazygitAction" text="Lazygit: Toggle" description="Toggle LazyGit window">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt g"/> </action>
    </actions>
</idea-plugin>