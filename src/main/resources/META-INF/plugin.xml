<idea-plugin require-restart="true">
    <id>dev.ckob.lazygit</id>
    <name>Lazygit</name>
    <vendor url="https://ckob.dev">ckob</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>
    <depends optional="true" config-file="lazygit-ideavim.xml">IdeaVIM</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.ckob.lazygit.LazygitEditorProvider"/>
        <applicationService serviceImplementation="dev.ckob.lazygit.LazygitSettingsState"/>
        <applicationConfigurable parentId="tools" instance="dev.ckob.lazygit.LazygitSettingsConfigurable" id="dev.ckob.lazygit.LazygitSettingsConfigurable" displayName="Lazygit"/>
    </extensions>

    <actions>
        <action id="Lazygit.Toggle" class="dev.ckob.lazygit.LazygitAction" text="Lazygit: Toggle (Project Root)" description="Toggle LazyGit window at the project root">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt g"/> 
        </action>
        <action id="Lazygit.ToggleCurrentDir" class="dev.ckob.lazygit.LazygitCurrentDirAction" text="Lazygit: Toggle (Current File Directory)" description="Toggle LazyGit window at the current file directory">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <!-- Add a default shortcut for the current dir action if needed, or leave it empty for user mapping -->
        </action>
    </actions>
</idea-plugin>